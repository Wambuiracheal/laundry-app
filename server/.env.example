DATABASE_URL="mysql://user:password@localhost:3306/laundry_db"
BE_PORT=5000
SESSION_SECRET="replace-with-a-strong-secret"

# Stable PASETO key pair (base64-encoded Ed25519 keys).
# Private key must decode to 64 bytes, public key must decode to 32 bytes.
# If omitted, server generates ephemeral keys and tokens become invalid after restart.
# PASETO_PRIVATE_KEY=""
# PASETO_PUBLIC_KEY=""

# Redis configuration: use REDIS_URL or REDIS_HOST + REDIS_PORT
REDIS_URL="redis://localhost:6379"
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Google OAuth redirects used by GET /api/auth/login/google and GET /api/auth/signup/google
# Set these to your backend OAuth start endpoints or provider auth URLs.
GOOGLE_LOGIN_URL="https://accounts.google.com/o/oauth2/v2/auth"
GOOGLE_SIGNUP_URL="https://accounts.google.com/o/oauth2/v2/auth"
